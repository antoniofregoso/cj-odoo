{
  "name": "@customerjourney/cj-odoo",
  "version": "1.7.0",
  "description": "json-rpc connection for odoo",
  "type": "module",
  "main": "dist/odooClient.js",
  "module": "dist/odooClient.min.js",
  "exports": {
    ".": {
      "import": "./dist/odooClient.min.js"
    }
  },
  "scripts": {
    "prod": "esbuild src/odooClient.js --bundle --minify --format=esm --outfile=dist/odooClient.min.js",
    "build": "esbuild src/odooClient.js --bundle --format=esm --outfile=dist/odooClient.js",
    "pretest": "npm run build",
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antoniofregoso/cj-odoo.git"
  },
  "homepage": "https://antoniofregoso.github.io/customerjourney/documentation/odoo/",
  "keywords": [
    "odoo",
    "JSON-RPC"
  ],
  "author": "Antonio Fregoso <antoniofregoso@protonmail.com>",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "esbuild": "^0.19.4"
  }
}
